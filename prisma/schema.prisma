generator client {
  provider = "prisma-client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String      @id @default(cuid())
  email               String      @unique
  name                String?
  password            String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  emailVerified       DateTime?
  image               String?
  ledTeams            EventTeam[] @relation("TeamLeaders")
  tickets             Ticket[]
  organizedEvents     Event[]     @relation("EventOrganizers")
  participatingEvents Event[]     @relation("EventParticipants")
}

model Event {
  id           String      @id @default(cuid())
  title        String
  tagline      String?
  category     String      @default("Technology")
  date         DateTime
  time         String?
  location     String?
  description  String?
  image        String?
  capacity     Int         @default(0)
  price        String?
  isFree       Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tags         String[]
  teams        EventTeam[]
  tickets      Ticket[]
  organizers   User[]      @relation("EventOrganizers")
  participants User[]      @relation("EventParticipants")
}

model Ticket {
  id             String     @id @default(cuid())
  status         String     @default("VALID")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  userId         String
  eventId        String
  teamId         String?
  event          Event      @relation(fields: [eventId], references: [id])
  teamMembership EventTeam? @relation("TeamMembers", fields: [teamId], references: [id])
  user           User       @relation(fields: [userId], references: [id])
}

model EventTeam {
  id        String   @id @default(cuid())
  code      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  eventId   String
  leaderId  String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leader    User     @relation("TeamLeaders", fields: [leaderId], references: [id])
  members   Ticket[] @relation("TeamMembers")

  @@unique([code, eventId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
